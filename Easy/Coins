public class Coins {
    public static void main(String[] args) {
        int[] A = {3,1,1};
        int[] B = {1,2,3};
        long mod = 1000000007;
        
        long totalCoins = 0;
        int n = A.length;
        for(int i=0; i<n; i++){
            totalCoins = (totalCoins + (A[i] * (1L << B[i]))%mod)%mod;
        }

        System.out.println(totalCoins);
    }
}
